{
	"name": "go-fmt-monorepo",
	"private": true,
	"scripts": {
		"build": "pnpm --filter orchestrator run build",
		"format": "make format",
		"format:support": "./scripts/with-storage-env.sh pnpm turbo run format --cache-dir=storage/.cache/turbo --filter=support",
		"test": "./scripts/with-storage-env.sh pnpm turbo run test --cache-dir=storage/.cache/turbo --filter=semantic --filter=correctness --filter=orchestrator",
		"vet": "./scripts/with-storage-env.sh pnpm turbo run vet --cache-dir=storage/.cache/turbo --filter=semantic --filter=correctness --filter=orchestrator"
	},
	"devDependencies": {
		"turbo": "2.5.8"
	},
	"packageManager": "pnpm@10.33.0"
}
