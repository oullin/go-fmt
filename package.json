{
	"name": "go-fmt-monorepo",
	"private": true,
	"scripts": {
		"build": "pnpm --filter driver run build",
		"format": "make format",
		"format:support": "./scripts/with-storage-env.sh pnpm turbo run format --cache-dir=storage/.cache/turbo --filter=support",
		"test": "./scripts/with-storage-env.sh pnpm turbo run test --cache-dir=storage/.cache/turbo --filter=formatter --filter=vet --filter=driver",
		"vet": "./scripts/with-storage-env.sh pnpm turbo run vet --cache-dir=storage/.cache/turbo --filter=formatter --filter=vet --filter=driver"
	},
	"devDependencies": {
		"turbo": "2.5.8"
	},
	"packageManager": "pnpm@10.33.0"
}
