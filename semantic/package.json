{
  "name": "semantic",
  "private": true,
  "scripts": {
    "build": "mkdir -p ../bin && CGO_ENABLED=${CGO_ENABLED:-0} go build -ldflags \"-X main.version=${VERSION:-dev}\" -o ../bin/fmt ./cmd/fmt",
    "check": "go run ./cmd/fmt check",
    "fmt-source": "gofmt -w .",
    "format": "go run ./cmd/fmt format",
    "test": "go test ./... -v",
    "vet": "go vet ./..."
  }
}
