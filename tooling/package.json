{
	"name": "tooling",
	"private": true,
	"scripts": {
		"check": "cd .. && git ls-files --cached --others --exclude-standard -z | xargs -0 tooling/node_modules/.bin/oxfmt --check --no-error-on-unmatched-pattern",
		"format": "cd .. && git ls-files --cached --others --exclude-standard -z | xargs -0 tooling/node_modules/.bin/oxfmt --write --no-error-on-unmatched-pattern"
	},
	"devDependencies": {
		"oxfmt": "0.41.0"
	}
}
